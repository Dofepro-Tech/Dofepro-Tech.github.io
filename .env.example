# AI_PROVIDER: Optional. Supported values: openrouter, gemini.
# If omitted, the backend prefers OPENROUTER_API_KEY and falls back to GEMINI_API_KEY.
AI_PROVIDER="openrouter"

# OPENROUTER_API_KEY: Recommended provider key for production and mobile publishing.
OPENROUTER_API_KEY="YOUR_OPENROUTER_API_KEY"

# OPENROUTER_MODEL: Example stable model. You can replace it later.
OPENROUTER_MODEL="openai/gpt-4o-mini"

# OPENROUTER_SITE_URL: Optional attribution header for OpenRouter rankings.
OPENROUTER_SITE_URL="http://localhost:3000"

# OPENROUTER_APP_NAME: Optional application title sent to OpenRouter.
OPENROUTER_APP_NAME="Biblia NJ"

# GEMINI_API_KEY: Optional fallback provider key if you still want Gemini support.
GEMINI_API_KEY=""

# GEMINI_MODEL: Optional Gemini model override.
GEMINI_MODEL="gemini-2.0-flash"

# PORT: Local port for the Express API server.
PORT="3001"

# API_PROXY_TARGET: Optional override for Vite dev and preview proxy.
API_PROXY_TARGET="http://localhost:3001"

# ALLOWED_ORIGINS: Optional comma-separated list for additional CORS origins.
ALLOWED_ORIGINS=""

# APP_URL: Public HTTPS origin of the backend when it is deployed.
APP_URL=""

# VITE_API_BASE_URL: Optional client-side API base for Capacitor/mobile builds.
# Example for local Android testing on the same Wi-Fi: http://192.168.0.103:3001
VITE_API_BASE_URL=""

# VITE_USE_SAME_ORIGIN_API: Set to true only when the web app is served by the same backend host.
VITE_USE_SAME_ORIGIN_API="false"

# REQUIRE_PUBLIC_API_BASE_URL: CI guard for public static builds. If true, build fails unless
# VITE_API_BASE_URL uses HTTPS or the app is built for same-origin backend hosting.
REQUIRE_PUBLIC_API_BASE_URL="false"

# VITE_APP_DOWNLOAD_URL: Public page where users can open the Bible online or download the latest APK.
VITE_APP_DOWNLOAD_URL="https://dofepro-tech.github.io/biblia-dj/"

# VITE_APP_UPDATE_URL: Optional explicit JSON manifest URL for in-app update checks.
# If omitted, the app derives /app-update.json from VITE_APP_DOWNLOAD_URL.
VITE_APP_UPDATE_URL=""

# VITE_APP_APK_URL: Optional explicit APK URL when the public landing and the APK live in different paths.
VITE_APP_APK_URL="https://dofepro-tech.github.io/biblia-dj-android.apk"

# VITE_PUBLIC_BASE_PATH: Base path for static hosts like GitHub Pages project sites.
# Examples: / for root domains, /biblia-dj/ for https://user.github.io/biblia-dj/
VITE_PUBLIC_BASE_PATH="/"
